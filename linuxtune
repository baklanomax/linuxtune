#!/usr/bin/env bash

apt update
apt -y upgrade
apt -y install gpm mc
apt -y autoremove

cat bash.bashrc > /etc/bash.bashrc
cat console-setup > /etc/default/console-setup
cat daemon.conf > /etc/gdm3/daemon.conf
cat grub > /etc/default/grub
cat logind.conf > /etc/systemd/logind.conf

mkdir /etc/systemd/system/getty@tty{3..15}.service.d/
cat override_root.conf > /etc/systemd/system/getty@tty3.service.d/override.conf
cat override_user.conf | tee /etc/systemd/system/getty@tty{4..12}.service.d/override.conf &> /dev/null
cat override_devel.conf | tee /etc/systemd/system/getty@tty{13..15}.service.d/override.conf &> /dev/null

chmod u+s /usr/sbin/kbdrate
update-grub

echo -e "\n\n\nНастройка успешно завершена."
