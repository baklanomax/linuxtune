#!/usr/bin/env bash


read -ep "Введите имя учётной записи для пользователя (по умолчанию user): " user
user=${user:-user}
if [[id -un $user != $user]]
then
	adduser --disabled-login --gecos "" $user
fi

read -ep "Введите имя учётной записи для разработчика (по умолчанию devel): " devel
devel=${devel:-devel}
if [[id -un $devel != $devel]]
then
	adduser --disabled-login --gecos "" $devel
fi


cat sources.list > /etc/apt/sources.list

apt update
apt -y upgrade
apt -y install firmware-atheros gpm mc
apt -y autoremove

cat bash.bashrc > /etc/bash.bashrc
cat console-setup > /etc/default/console-setup
cat daemon.conf | sed "s/=user/=$user/" > /etc/gdm3/daemon.conf
cat inputrc > /etc/inputrc
cat grub > /etc/default/grub
cat logind.conf > /etc/systemd/logind.conf

mkdir /etc/systemd/system/getty@tty{3..15}.service.d/
cat override_root.conf | tee /etc/systemd/system/getty@tty{3,4}.service.d/override.conf &> /dev/null
cat override_user.conf | sed "s/user/$user/" | tee /etc/systemd/system/getty@tty{5..13}.service.d/override.conf &> /dev/null
cat override_devel.conf | sed "s/devel/$devel/" | tee /etc/systemd/system/getty@tty{14,15}.service.d/override.conf &> /dev/null

chmod u+s /usr/sbin/kbdrate
update-grub

echo -e "\n\n\nНастройка успешно завершена."
