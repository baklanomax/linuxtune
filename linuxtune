#!/usr/bin/env bash

while true
do
	read -ep "Введите имя учётной записи для пользователя (по умолчанию user): " user
	user=${user:-user}
	if [[ $(id -un $user 2> /dev/null) == $user ]]
	then
		break
	else
		adduser --disabled-login --gecos "" $user 2> /dev/null && break || echo "Ошибка: недопустимое имя учётной записи"	
	fi
done

while true
do
	read -ep "Введите имя учётной записи для разработчика (по умолчанию devel): " devel
	devel=${devel:-devel}
	if [[ $(id -un $devel 2> /dev/null) == $devel ]]
	then
		break
	else
		adduser --disabled-login --gecos "" $devel 2> /dev/null && break || echo "Ошибка: недопустимое имя учётной записи"
	fi
done

cat sources.list > /etc/apt/sources.list

apt update
apt -y upgrade
apt -y install firmware-amd-graphics firmware-atheros firmware-iwlwifi gpm mc tmux
apt -y autoremove

cat bash.bashrc > /etc/bash.bashrc
cat console-setup > /etc/default/console-setup
sed "s/=user/=$user/" daemon.conf > /etc/gdm3/daemon.conf
cat inputrc > /etc/inputrc
cat grub > /etc/default/grub
cat logind.conf > /etc/systemd/logind.conf

mkdir /etc/systemd/system/getty@tty{3..15}.service.d/
cat override_root.conf | tee /etc/systemd/system/getty@tty{3,4}.service.d/override.conf &> /dev/null
sed "s/user/$user/" override_user.conf | tee /etc/systemd/system/getty@tty{5..13}.service.d/override.conf &> /dev/null
sed "s/devel/$devel/" override_devel.conf | tee /etc/systemd/system/getty@tty{14,15}.service.d/override.conf &> /dev/null

sudo -u $user dbus-launch gsettings set org.gnome.desktop.peripherals.keyboard delay 2000
sudo -u $user dbus-launch gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 110
sudo -u $user dbus-launch gsettings set org.gnome.desktop.screensaver lock-delay 0
sudo -u $user dbus-launch gsettings set org.gnome.desktop.screensaver lock-enabled false

mkdir -m 700 /root/{.config/,.config/mc/}
sudo -u $user mkdir -m 700 /home/$user/{.config/,.config/mc/}
sudo -u $devel mkdir -m 700 /home/$devel/{.config/,.config/mc/}
cat ini > /root/.config/mc/ini
cat ini | sudo -u $user tee /home/$user/.config/mc/ini &> /dev/null
cat ini | sudo -u $devel tee /home/$devel/.config/mc/ini &> /dev/null

/etc/fstab
/etc/initramfs-tools/conf.d/resume

chmod u+s /usr/sbin/kbdrate
update-initramfs -u -k all
update-grub

echo -e "\n\n\nНастройка успешно завершена."
